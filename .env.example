# ─────────────────────────────────────────────
#  Hostachy — Configuration (copier vers .env)
# ─────────────────────────────────────────────

# Domaine public (Caddy TLS auto)
DOMAIN=example.com
ORIGIN=https://example.com

# Sécurité
SECRET_KEY=changez-cette-valeur-secrete-en-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=true   # false uniquement pour le développement HTTP local
ENABLE_API_DOCS=false  # true pour exposer /docs et /redoc (dev uniquement)

# Base de données
DATABASE_URL=sqlite:////app/data/app.db

# Email (SMTP ou relay)
MAIL_ENABLED=false
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME="Ma Résidence"
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SERVER=smtp.mailgun.org
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# Sauvegardes
BACKUP_DIR=/backups
BACKUP_FREQUENCY=weekly      # daily | weekly | monthly
BACKUP_HOUR=3
BACKUP_DAY_OF_WEEK=6         # 0=lundi … 6=dimanche
BACKUP_KEEP_VERSIONS=3

# Maintenance cron (clé partagée script ↔ API)
MAINTENANCE_KEY=

# WhatsApp (whatsapp-bridge)
WHATSAPP_API_KEY=changez-cette-cle-whatsapp-min-16-chars

# OAuth (optionnel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
